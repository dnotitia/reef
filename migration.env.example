# Copy to .env.migration.local for isolated local development only.
# Never reuse a production key. The key is loaded by the root pnpm dev wrapper,
# used once by the schema runner, and removed from the Next.js child environment.
AKB_BACKEND_URL=http://localhost:8000
REEF_AKB_MIGRATION_SERVICE_ACCOUNT=reef-migrator
REEF_AKB_MIGRATION_SERVICE_KEY=replace-with-local-service-key
