# reef server-side env. Per-user secrets are NOT here — the akb session lives in
# an httpOnly cookie; GitHub credentials are deployment-managed server secrets.
# See packages/web/.env.example for the akb backend URL.

# ── OpenRouter / LLM (server-managed) ────────────────────────────────────────
# Used by reef-web AI routes. In Kubernetes, OPENROUTER_API_KEY is provided by
# the `reef-web-secret` Secret; OPENROUTER_BASE_URL and REEF_LLM_MODEL live in
# the ConfigMap.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
REEF_LLM_MODEL=deepseek/deepseek-v4-flash

# Managed akb-platform profile (mutually exclusive with OPENROUTER_* above).
# The platform injects the component-scoped gateway key. Both URLs must be the
# same canonical OpenAI-compatible gateway base or reef-web fails readiness.
# REEF_LLM_GOVERNANCE_MODE=platform_hard
# REEF_LLM_API_KEY=
# REEF_LLM_BASE_URL=https://gateway.example.com/v1
# REEF_PLATFORM_GATEWAY_BASE_URL=https://gateway.example.com/v1

# ── GitHub App (server-managed monitored-repo grounding, optional) ─────────────
# When all three are set, reef-web mints a read-only installation token so the
# monitored-repo picker and activity grounding work without browser-supplied
# GitHub tokens. When unset, local/CI can use the optional
# server PAT fallback below; otherwise GitHub-specific features are unavailable.
# In Kubernetes, REEF_GITHUB_APP_PRIVATE_KEY is provided by the `reef-web-secret`
# Secret; the two ids live in the ConfigMap.
# REEF_GITHUB_APP_PRIVATE_KEY is the App's PEM private key; a single-line value
# with literal `\n` escapes is accepted (newlines are restored at load).
# SECURITY: the private key is a secret — it must NEVER appear in logs, span
# attributes, LLM prompts, or response bodies.
REEF_GITHUB_APP_ID=
REEF_GITHUB_APP_INSTALLATION_ID=
REEF_GITHUB_APP_PRIVATE_KEY=

# ── GitHub PAT fallback (server-managed, dev/CI only) ──────────────────────────
# Interim stand-in for the GitHub App in local development and CI, where wiring a
# full App is overkill but a real read-only GitHub I/O path is still needed to
# exercise grounding, the activity scan, and the monitored-repo picker. When set
# (and no App is configured), reef-web reads GitHub with this token so those
# surfaces work without browser-supplied GitHub tokens.
# Credential precedence is App → server PAT, so this is DISABLED unless set and
# never overrides a configured App — it must not become a deployment's
# production credential. Use a fine-grained, read-only PAT scoped like the App
# installation (contents:read, metadata:read, pull_requests:read).
# SECURITY: this is a deployment secret like the App private key — it must NEVER
# appear in logs, span attributes, LLM prompts, or response bodies.
REEF_GITHUB_PAT=

# ── Login / SSO (optional) ─────────────────────────────────────────────────────
# When set to 1 and the akb backend reports workspace SSO (Keycloak) enabled,
# /login sends visitors straight to SSO instead of showing the "Continue with
# workspace SSO" button first. The decision is server-side, so there is no panel
# flash before the bounce. It never fires on an SSO/session error and always
# leaves the password escape hatch (/login?password=1 or ?prompt=login)
# reachable, so password sign-in stays available if SSO is down. Unset (default)
# keeps the button-first login panel.
# REEF_SSO_AUTO_REDIRECT=1

# ── OpenTelemetry / Langfuse (optional — enables AI trace export) ──────────────
# OTLP HTTP base endpoint for trace export. Point at an OTEL Collector or
# self-hosted Langfuse. The instrumentation appends `/v1/traces` to this base —
# so set the base host:port WITHOUT a trailing path segment.
# To override the full URL (skip the `/v1/traces` suffix), set
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT instead.
# Defaults to http://localhost:4318/v1/traces when unset (no-op if nothing is
# listening there).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Comma-separated key=value HTTP headers sent on every OTLP export request.
# Used to authenticate with the trace backend.
# SECURITY: these values are read once at startup and injected into the OTLP
# exporter — they must NEVER appear in span attributes, log output, or response
# bodies. Keep them out of version control.
OTEL_EXPORTER_OTLP_HEADERS=

# ── Backend logging (optional) ────────────────────────────────────────────────
# Emit the per-request `response` access line (status + duration) and the backend
# `core` observability lines (activity-scan checkpoints, LLM token usage) on
# stdout in ANY environment. On by default only in development. Set to 1 for a
# deployment WITHOUT a trace backend, where those signals would otherwise be
# invisible. See docs/deployment.md → "Backend logging and the prod access-line
# policy".
# REEF_RESPONSE_LOG=1
# Threshold (ms) at/above which a `response` line is logged at WARN instead of
# INFO, so a slow request stands out. Defaults to 1000.
# REEF_SLOW_REQUEST_MS=1000
# pino log level (debug|info|warn|error). Defaults to debug in development, info
# otherwise.
# LOG_LEVEL=info
