# reef server-side env. Per-user secrets are NOT here — the akb session
# lives in an httpOnly cookie and the GitHub PAT in browser IndexedDB.
# See packages/web/.env.example for the akb backend URL.

# ── OpenRouter / LLM (server-managed) ────────────────────────────────────────
# Used by reef-web AI routes. In Kubernetes, OPENROUTER_API_KEY is provided by
# the `reef-web-secret` Secret; OPENROUTER_BASE_URL and REEF_LLM_MODEL live in
# the ConfigMap.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
REEF_LLM_MODEL=deepseek/deepseek-v4-flash

# ── GitHub App (server-managed monitored-repo grounding, optional) ─────────────
# When all three are set, reef-web mints a read-only installation token so the
# monitored-repo picker and activity grounding work without each browser user
# supplying a personal access token. When unset, reef falls back to the per-user
# browser PAT. In Kubernetes, REEF_GITHUB_APP_PRIVATE_KEY is provided by the
# `reef-web-secret` Secret; the two ids live in the ConfigMap.
# REEF_GITHUB_APP_PRIVATE_KEY is the App's PEM private key; a single-line value
# with literal `\n` escapes is accepted (newlines are restored at load).
# SECURITY: the private key is a secret — it must NEVER appear in logs, span
# attributes, LLM prompts, or response bodies.
REEF_GITHUB_APP_ID=
REEF_GITHUB_APP_INSTALLATION_ID=
REEF_GITHUB_APP_PRIVATE_KEY=

# ── OpenTelemetry / Langfuse (optional — enables AI trace export) ──────────────
# OTLP HTTP base endpoint for trace export. Point at an OTEL Collector or
# self-hosted Langfuse. The instrumentation appends `/v1/traces` to this base —
# so set the base host:port WITHOUT a trailing path segment.
# To override the full URL (skip the `/v1/traces` suffix), set
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT instead.
# Defaults to http://localhost:4318/v1/traces when unset (no-op if nothing is
# listening there).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Comma-separated key=value HTTP headers sent on every OTLP export request.
# Used to authenticate with the trace backend.
# SECURITY: these values are read once at startup and injected into the OTLP
# exporter — they must NEVER appear in span attributes, log output, or response
# bodies. Keep them out of version control.
OTEL_EXPORTER_OTLP_HEADERS=
