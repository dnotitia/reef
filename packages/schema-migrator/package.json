    "start": "tsx src/cli.ts"
  },
  "dependencies": {
    "@reef/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "esbuild": "0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
