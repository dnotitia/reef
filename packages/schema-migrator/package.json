{
  "name": "@reef/schema-migrator",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/cli.mjs",
  "bin": {
    "reef-schema-migrator": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/cli.mjs",
