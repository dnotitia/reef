{
  "name": "@reef/schema-migrator",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "reef-schema-migrator": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild src/cli.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/cli.mjs",
    "dev:wrapper": "node --env-file-if-exists=../../.env.migration.local --import tsx src/dev.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@reef/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
