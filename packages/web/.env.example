# reef-web environment variables.
#
# Mostly server-only values. Anything that needs to reach the browser must use a
# NEXT_PUBLIC_* prefix; the only one is NEXT_PUBLIC_AKB_WEB_URL below (a public
# address, not a secret). LLM and GitHub App credentials stay
# server-side; the akb session lives in an httpOnly cookie.

# Base URL of the akb backend. In-cluster: http://backend.akb.svc.cluster.local:8000
# Local dev: http://localhost:8000 (or a port-forward into the cluster)
AKB_BACKEND_URL=http://localhost:8000

# Non-secret migration service username. Workspace creation grants this actor
# exact writer membership before writing the Reef marker. The matching key does
# NOT belong here; local pnpm dev loads it from .env.migration.local only.
REEF_AKB_MIGRATION_SERVICE_ACCOUNT=reef-migrator

# Canonical external origin of THIS reef deployment, e.g. https://reef-acme.example.com
# (REEF-137). Server-only; NEVER NEXT_PUBLIC and never derived from the request
# Host. When set, reef hands akb an absolute SSO callback on this origin so akb's
# `keycloak_post_login_allowed_origins` allowlist returns the one-time login code
# to reef instead of akb's own SPA — letting akb-frontend SSO and reef SSO coexist
# on the same tenant Keycloak. Must be a bare origin (scheme://host[:port], no
# default :443, no trailing path), https except for localhost/loopback dev (the
# callback carries the one-time login code), and match the allowlist entry exactly.
# Unset → reef keeps the legacy same-site callback (single-target / akb-SPA-only).
# REEF_PUBLIC_ORIGIN=https://reef-acme.example.com

# Optional SSO-first override for a hybrid AKB. AKB's public auth config remains
# authoritative: keycloak.sso_only=true redirects without this variable, while
# local_auth.enabled=false hides password login even with ?password=1 or
# ?prompt=login. Errors suppress automatic redirects as the loop guard.
# REEF_SSO_AUTO_REDIRECT=1

# Public base URL of the akb web app, used to open a linked document in a new tab
# from an issue's "Linked documents" section (REEF-083). Unset → the open action
# is hidden and only copy-URI is offered. Not a secret; safe to inline in the
# browser bundle.
# NEXT_PUBLIC_AKB_WEB_URL=https://akb.example.com

# Optional deployment-managed OpenAI-compatible LLM endpoint. Set all three to
# enable AI, or leave all three empty for a valid disabled state. The URL can
# point to OpenRouter or an akb-platform gateway; Reef does not classify it.
REEF_LLM_API_KEY=
REEF_LLM_BASE_URL=
REEF_LLM_MODEL=

# Deployment-managed GitHub App used for monitored-repo listing, grounding, and
# activity scans. Browser users do not paste or store GitHub tokens.
# REEF_GITHUB_APP_ID=
# REEF_GITHUB_APP_INSTALLATION_ID=
# REEF_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Optional dev/CI fallback when no GitHub App is configured. This is still a
# deployment-managed server secret, not a per-user browser token.
# REEF_GITHUB_PAT=
