{
  "name": "@reef/orchestrator",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "reef-orchestrator": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "tsx src/cli.ts",
    "smoke:dry-run": "tsx src/cli.ts --dry-run"
  },
  "dependencies": {
    "@reef/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.20.3",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
