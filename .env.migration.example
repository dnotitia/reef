# Local startup migration identity. Copy to `.env.migration.local` and use only
# an isolated development AKB workspace. Never reuse production credentials.
REEF_SCHEMA_MIGRATION_KEY=

# These values are non-secret and are also needed by reef-web. They may instead
# be supplied by the shell or packages/web/.env.local.
AKB_BACKEND_URL=http://localhost:8000
REEF_SCHEMA_SERVICE_USERNAME=reef-schema-migrator
