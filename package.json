{
  "name": "reef-workspace",
  "version": "0.4.0",
  "private": true,
  "license": "Apache-2.0",
  "author": "Dnotitia Inc.",
  "homepage": "https://github.com/dnotitia/reef#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnotitia/reef.git"
  },
  "bugs": {
    "url": "https://github.com/dnotitia/reef/issues"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "biome check .",
    "check:release": "node scripts/check-release-policy.mjs",
    "maintenance:scan": "node scripts/maintenance/scan.mjs",
    "maintenance:assert-clean": "node scripts/maintenance/scan.mjs --assert-clean",
    "maintenance:duplicates": "node scripts/maintenance/scan.mjs duplicates",
    "maintenance:dead-code": "node scripts/maintenance/scan.mjs dead-code",
    "maintenance:lint": "node scripts/maintenance/scan.mjs maintenance-lint",
    "maintenance:large-files": "node scripts/maintenance/scan.mjs large-files",
    "maintenance:test-profile": "node scripts/maintenance/scan.mjs slow-tests",
    "maintenance:comments": "node scripts/maintenance/scan.mjs comment-claims",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jscpd": "^5.0.6",
    "knip": "^6.16.1",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "@grpc/grpc-js": "1.14.4",
      "@grpc/proto-loader": "0.8.1",
      "@opentelemetry/core": "2.8.0",
      "@protobufjs/utf8": "1.1.1",
      "dompurify": "3.4.9",
      "esbuild": "0.28.1",
      "form-data": "4.0.6",
      "markdown-it": "14.2.0",
      "mermaid": "11.15.0",
      "postcss": "8.5.15",
      "protobufjs": "7.6.4",
      "vite": "6.4.3",
      "ws": "8.21.0"
    }
  }
}
